{
  "manifest_version": 3,
  "name": "SE-Billing",
  "version": "2.7.8",
  "description": "Auto-fill ค่าบริการในระบบ I Survey (cloud.isurvey.mobi) ตามจังหวัด/อำเภอ/ประเภทเคลม + บันทึก log การกรอกฟอร์มไปยัง SE-Billing server",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://cloud.isurvey.mobi/*",
    "https://billing.sesurvey.cloud/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SE-Billing — เลือกจังหวัด",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://cloud.isurvey.mobi/*"],
      "js": ["loader.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": false
    },
    {
      "matches": ["https://cloud.isurvey.mobi/*"],
      "js": ["config-bridge.js", "content.js", "feature-out-of-area-amount.js", "feature-out-of-hours-amount.js", "feature-deduct-amount.js", "feature-sub-area-checkbox.js"],
      "run_at": "document_idle",
      "world": "MAIN",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data/provinces.json", "data/amphurs.json", "data/tumbons.json"],
      "matches": ["https://cloud.isurvey.mobi/*"]
    }
  ]
}
