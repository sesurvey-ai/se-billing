{
  "manifest_version": 3,
  "name": "I Survey Auto-Fill Helper",
  "version": "1.2.0",
  "description": "Auto-fill ค่าบริการในระบบ I Survey (cloud.isurvey.mobi) ตามจังหวัด/อำเภอ/ตำบล + modifier (นอกพื้นที่/นอกเวลา)",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://cloud.isurvey.mobi/*"],
      "js": ["loader.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": false
    },
    {
      "matches": ["https://cloud.isurvey.mobi/*"],
      "js": ["config.js", "content.js"],
      "run_at": "document_idle",
      "world": "MAIN",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data/provinces.json", "data/amphurs.json", "data/tumbons.json"],
      "matches": ["https://cloud.isurvey.mobi/*"]
    }
  ]
}
